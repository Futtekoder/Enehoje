generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums for Calendar
enum WeekAssignmentType {
  SHARE
  COMMON
  OPENING
  CLOSING
  BLOCKED
}

enum WeekAssignmentSource {
  GENERATED
  MANUAL
}

enum CalendarEventType {
  GENERAL_ASSEMBLY
  WORK_WEEKEND
  MEETING
  MAINTENANCE
  OTHER
}

// Models

model Share {
  id         String   @id @default(uuid())
  code       String?  @unique // e.g. "FK", "OT", "AF", "KP", "HT"
  name       String
  color      String?
  voteWeight Decimal  @default(1.0)
  createdAt  DateTime @default(now())

  users           User[]
  memberships     ShareMembership[]
  weeks           Week[]
  weekAssignments WeekAssignment[]
  sequenceItems   ShareSequenceItem[]

  requestedSwaps SwapRequest[] @relation("RequestingShare")
  receivedSwaps  SwapRequest[] @relation("ReceivingShare")

  // Planning Hub relations
  events Event[]
}

model ShareMembership {
  userId  String
  shareId String

  isChair Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  share Share @relation(fields: [shareId], references: [id], onDelete: Cascade)

  @@id([userId, shareId])
  @@index([shareId])
  @@index([userId])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("MEMBER") // ENUM: MEMBER, ANDEL_ADMIN, SYSTEM_ADMIN
  status        String    @default("PENDING") // ENUM: PENDING, APPROVED, REJECTED
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  shareId     String?
  share       Share?            @relation(fields: [shareId], references: [id])
  memberships ShareMembership[]

  accounts      Account[]
  sessions      Session[]
  posts         Post[]
  comments      Comment[]
  votes         Vote[]
  messages      Message[]
  conversations ConversationParticipant[]

  // Planning Hub relations
  createdEvents     Event[]              @relation("EventCreator")
  createdGroups     EventGroup[]         @relation("GroupCreator")
  eventGroupMembers EventGroupMember[]
  participations    EventParticipation[]
  sailingWishes     SailingWish[]
  createdTasks      EventTask[]          @relation("TaskCreator")
  approvedTasks     EventTask[]          @relation("TaskApprover")
  taskSignups       TaskSignup[]
  taskVotes         TaskVote[]
}

model Week {
  id         String   @id @default(uuid())
  year       Int
  weekNumber Int
  shareId    String
  share      Share    @relation(fields: [shareId], references: [id])
  source     String   @default("BASELINE") // ENUM: BASELINE, ROTATION, SWAP, OVERRIDE
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([year, weekNumber])
}

model SwapRequest {
  id                String   @id @default(uuid())
  requestingShareId String
  receivingShareId  String
  year              Int
  weekA             Int
  weekB             Int
  status            String   @default("PENDING") // ENUM: PENDING, ACCEPTED, REJECTED, CANCELLED
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  requestingShare Share         @relation("RequestingShare", fields: [requestingShareId], references: [id])
  receivingShare  Share         @relation("ReceivingShare", fields: [receivingShareId], references: [id])
  conversation    Conversation?
}

model Conversation {
  id        String   @id @default(uuid())
  title     String? // Optional: for group chats (e.g., "Bestyrelsen")
  isGroup   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants ConversationParticipant[]
  messages     Message[]

  swapRequestId String?      @unique
  swapRequest   SwapRequest? @relation(fields: [swapRequestId], references: [id], onDelete: Cascade)
}

model ConversationParticipant {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  authorId       String
  author         User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content        String       @db.Text
  createdAt      DateTime     @default(now())
}

model Post {
  id        String   @id @default(uuid())
  title     String
  content   String
  category  String   @default("General")
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments    Comment[]
  attachments Attachment[]
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Attachment {
  id        String   @id @default(uuid())
  url       String
  filename  String
  mimeType  String
  size      Int
  postId    String?
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Folder {
  id        String     @id @default(uuid())
  name      String
  parentId  String?
  parent    Folder?    @relation("FolderHierarchy", fields: [parentId], references: [id])
  children  Folder[]   @relation("FolderHierarchy")
  documents Document[]
  createdAt DateTime   @default(now())

  // Planning Hub relations
  eventTasks EventTask[]
}

model Document {
  id        String   @id @default(uuid())
  title     String
  url       String
  folderId  String?
  folder    Folder?  @relation(fields: [folderId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Poll {
  id        String    @id @default(uuid())
  question  String
  deadline  DateTime?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())

  options PollOption[]
  votes   Vote[]
}

model PollOption {
  id     String @id @default(uuid())
  text   String
  pollId String
  poll   Poll   @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes  Vote[]
}

model Vote {
  id        String     @id @default(uuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id])
  pollId    String
  poll      Poll       @relation(fields: [pollId], references: [id])
  optionId  String
  option    PollOption @relation(fields: [optionId], references: [id])
  createdAt DateTime   @default(now())

  @@unique([userId, pollId])
}

// NextAuth necessary models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

// Calendar System v1 Models

model WeekAssignment {
  id         String             @id @default(cuid())
  year       Int
  weekNumber Int // 1..52/53
  type       WeekAssignmentType

  shareId String? // FK/OT/AF/KP/HT mapped when type=SHARE
  share   Share?  @relation(fields: [shareId], references: [id])

  note     String?
  isLocked Boolean              @default(false) // true for Ascension common week
  source   WeekAssignmentSource @default(GENERATED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([year, weekNumber])
  @@index([year])
}

model CalendarEvent {
  id          String            @id @default(cuid())
  title       String
  type        CalendarEventType
  description String?
  startDate   DateTime
  endDate     DateTime
  allDay      Boolean           @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startDate])
}

model CalendarSettings {
  id                          String  @id @default(cuid())
  anchorShareIndex            Int     @default(0) // start index in base sequence for week 1
  includeHolidaysInIcs        Boolean @default(true)
  includeWeekAssignmentsInIcs Boolean @default(true)
}

model ShareSequenceItem {
  id       String @id @default(cuid())
  position Int
  shareId  String
  share    Share  @relation(fields: [shareId], references: [id])

  @@unique([position])
  @@index([position])
}

// ----------------------------------------------------------------------------
// PLANNING HUB (Phase 2) Models
// ----------------------------------------------------------------------------

enum EventType {
  WORK_WEEKEND
  COMMON_WEEKEND
  SHARE_STAY
  OTHER
}

enum EventScope {
  ALL_MEMBERS
  SHARE
  MIXED_GROUP
}

enum EventVisibility {
  MEMBERS
  ADMINS_ONLY
}

enum EventStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Event {
  id              String          @id @default(cuid())
  title           String
  description     String?
  type            EventType
  scope           EventScope
  startAt         DateTime
  endAt           DateTime
  createdByUserId String
  shareId         String? // Nullable, used if scope=SHARE
  visibility      EventVisibility @default(MEMBERS)
  status          EventStatus     @default(PUBLISHED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  share         Share? @relation(fields: [shareId], references: [id])
  createdByUser User   @relation("EventCreator", fields: [createdByUserId], references: [id])

  groups         EventGroup[]
  participations EventParticipation[]
  sailingWishes  SailingWish[]
  tasks          EventTask[]
}

model EventGroup {
  id              String @id @default(cuid())
  eventId         String
  name            String
  createdByUserId String

  event         Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdByUser User  @relation("GroupCreator", fields: [createdByUserId], references: [id])

  members EventGroupMember[]
}

model EventGroupMember {
  id           String @id @default(cuid())
  eventGroupId String
  userId       String

  group EventGroup @relation(fields: [eventGroupId], references: [id], onDelete: Cascade)
  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventGroupId, userId])
}

enum ParticipationMode {
  ON_ISLAND
  NOT_ON_ISLAND
  MAYBE
}

model EventParticipation {
  id       String            @id @default(cuid())
  eventId  String
  userId   String
  mode     ParticipationMode
  fromDate DateTime          @db.Date
  toDate   DateTime          @db.Date
  comment  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId, fromDate, toDate])
}

enum SailingDirection {
  ARRIVAL
  DEPARTURE
}

enum SailingFlexibility {
  FIXED
  FLEX_1H
  FLEX_3H
  FLEX_SAME_DAY
}

enum SailingLocation {
  LANGOE_HAVN
  OTHER
}

model SailingWish {
  id              String             @id @default(cuid())
  eventId         String
  userId          String
  direction       SailingDirection
  desiredAt       DateTime
  timeFlexibility SailingFlexibility
  fromLocation    SailingLocation
  seats           Int                @default(1)
  notes           String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum TaskCategory {
  PROJECT
  COOKING
  SHOPPING
  PACKING
  MAINTENANCE
  OTHER
}

enum TaskCriticality {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskStatus {
  PROPOSED
  APPROVED
  REJECTED
  ACTIVE
  DONE
}

model EventTask {
  id                 String          @id @default(cuid())
  eventId            String
  title              String
  description        String?
  category           TaskCategory
  criticality        TaskCriticality
  status             TaskStatus
  createdByUserId    String
  approvedByUserId   String?
  approvedAt         DateTime?
  dueDate            DateTime?
  attachmentFolderId String?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  event            Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdByUser    User    @relation("TaskCreator", fields: [createdByUserId], references: [id])
  approvedByUser   User?   @relation("TaskApprover", fields: [approvedByUserId], references: [id])
  attachmentFolder Folder? @relation(fields: [attachmentFolderId], references: [id])

  signups TaskSignup[]
  votes   TaskVote[]
}

model TaskSignup {
  id        String  @id @default(cuid())
  taskId    String
  userId    String
  roleLabel String?

  task EventTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
}

model TaskVote {
  id     String @id @default(cuid())
  taskId String
  userId String
  vote   Int // 1 for UP, -1 for DOWN, or 1-5 rating

  task EventTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
}

// -----------------------------------------
// DRIFT & CHECKLISTER (OPERATIONS HUB)
// -----------------------------------------

model OperationUnit {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  icon        String?
  order       Int      @default(0)

  sections    OperationSection[]
}

model OperationSection {
  id            String   @id @default(cuid())
  unitId        String
  title         String
  slug          String
  description   String?

  videoKey      String?
  videoSize     Int?

  order         Int      @default(0)
  isQuickAction Boolean  @default(false)

  unit          OperationUnit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  checklist     OperationChecklistItem[]

  @@unique([unitId, slug])
}

model OperationChecklistItem {
  id        String @id @default(cuid())
  sectionId String
  text      String
  order     Int    @default(0)

  section   OperationSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
}
